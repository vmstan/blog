---
interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;
const newerHref = currentPage === 2 ? "/" : `/page/${currentPage - 1}/`;
const olderHref = `/page/${currentPage + 1}/`;
---

<nav class="pagination" aria-label="Post pages">
  {
    currentPage > 1 ? (
      <a href={newerHref}><span aria-hidden="true">←</span> Newer posts</a>
    ) : (
      <span />
    )
  }
  <span>Page {currentPage} of {totalPages}</span>
  {
    currentPage < totalPages ? (
      <a href={olderHref}>Older posts <span aria-hidden="true">→</span></a>
    ) : (
      <span />
    )
  }
</nav>
