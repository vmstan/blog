    "astro": "^7.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "husky": "^9.1.7",
    "pagefind": "^1.5.2",
    "typescript": "^6.0.0",
    "wrangler": "^4.113.0"
  }
}
