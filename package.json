{
  "name": "virtually-benevolent",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
